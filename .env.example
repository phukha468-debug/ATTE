# === ПУБЛИЧНЫЕ КЛЮЧИ (Доступны во фронтенде через import.meta.env) ===
# Эти ключи начинаются с VITE_, так как Vite пробрасывает их в бандл.
# Они защищены не секретностью, а правилами RLS в Supabase.

VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="ваш_публичный_ключ_anon"

# === СЕКРЕТНЫЕ КЛЮЧИ (ТОЛЬКО для Vercel Serverless Functions) ===
# Эти ключи НИКОГДА не должны иметь префикс VITE_.
# Если добавить VITE_, они утекут в браузер пользователя.

# Секретный ключ администратора Supabase
SUPABASE_SERVICE_ROLE_KEY="ваш_секретный_ключ_service_role"

# Токен вашего Telegram-бота (от BotFather)
TG_BOT_TOKEN="123456789:ABCDEF..."

# Ключ OpenRouter для работы с ИИ
OPENROUTER_API_KEY="sk-or-v1-..."